# SJF Scheduling Algorithm

n = int(input("Enter number of processes: "))

processes = []
burst_time = []

for i in range(n):
    bt = int(input(f"Enter Burst Time for Process P{i+1}: "))
    burst_time.append(bt)
    processes.append(f"P{i+1}")

# Sorting according to burst time
combined = list(zip(processes, burst_time))
combined.sort(key=lambda x: x[1])

processes = [x[0] for x in combined]
burst_time = [x[1] for x in combined]

waiting_time = [0] * n
turnaround_time = [0] * n

# Calculate Waiting Time
for i in range(1, n):
    waiting_time[i] = waiting_time[i-1] + burst_time[i-1]

# Calculate Turnaround Time
for i in range(n):
    turnaround_time[i] = waiting_time[i] + burst_time[i]

# Display Results
print("\nProcess\tBurst Time\tWaiting Time\tTurnaround Time")

for i in range(n):
    print(f"{processes[i]}\t{burst_time[i]}\t\t{waiting_time[i]}\t\t{turnaround_time[i]}")

avg_wt = sum(waiting_time) / n
avg_tat = sum(turnaround_time) / n

print("\nAverage Waiting Time =", avg_wt)
print("Average Turnaround Time =", avg_tat)
